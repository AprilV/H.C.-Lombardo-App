# H.C. Lombardo App environment template
# Copy this file to .env for backend local runtime.

# PostgreSQL connection settings (backend)
# Required for non-local DB auth flows.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nfl_analytics
DB_USER=postgres
DB_PASSWORD=

# Optional full DB URL used by some utilities.
DATABASE_URL=

# Frontend API endpoint (set in frontend/.env.local or CI env vars).
# Included here as a documentation reference for required variable inventory.
REACT_APP_API_URL=https://api.aprilsykes.dev
