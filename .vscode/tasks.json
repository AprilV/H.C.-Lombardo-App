{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "H.C. Lombardo - Start NFL API (Live Server)",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "uvicorn",
                "apis.nfl_betting_api:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8001"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false,
                "group": "H.C. Lombardo APIs"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
