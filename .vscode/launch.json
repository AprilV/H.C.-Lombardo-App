{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run FastAPI (Live Server)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apis.nfl_betting_api:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8001"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "jinja": true
        },
        {
            "name": "H.C. Lombardo FastAPI - Template App",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apis.fastapi_template_inheritance:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8001",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "presentation": {
                "group": "H.C. Lombardo APIs",
                "order": 1
            }
        },
        {
