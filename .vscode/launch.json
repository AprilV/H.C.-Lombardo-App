    "compounds": [
        {
            "name": "H.C. Lombardo - Start All APIs",
            "configurations": [
                "H.C. Lombardo FastAPI - Template App",
                "H.C. Lombardo FastAPI - NFL Betting API", 
                "H.C. Lombardo FastAPI - Text Classification API"
            ],
            "presentation": {
                "group": "H.C. Lombardo APIs",
                "order": 5
